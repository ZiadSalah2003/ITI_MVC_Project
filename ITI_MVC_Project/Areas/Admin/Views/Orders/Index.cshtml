@model AdminOrderListVM
@{ ViewData["Title"] = "Manage Orders"; }
<h2>All Orders</h2>
<div class="table-responsive">
<table class="table table-striped">
    <thead class="table-dark"><tr><th>Order #</th><th>Customer</th><th>Email</th><th>Date</th><th>Total</th><th>Status</th><th>Items</th><th></th></tr></thead>
    <tbody>
        @foreach (var o in Model.Orders)
        {
            <tr>
                <td>#@o.Id</td>
                <td>@o.CustomerName</td>
                <td>@o.CustomerEmail</td>
                <td>@o.OrderDate.ToString("MMM dd, yyyy")</td>
                <td>$@o.TotalAmount.ToString("N2")</td>
                <td><span class="badge bg-primary">@o.Status</span></td>
                <td>@o.ItemCount</td>
                <td><a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">Details</a></td>
            </tr>
        }
    </tbody>
</table>
</div>