@model List<AdminProductVM>
@{ ViewData["Title"] = "Manage Products"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Products</h2>
    <a asp-action="Create" class="btn btn-primary">Add Product</a>
</div>
<div class="table-responsive">
<table class="table table-striped">
    <thead class="table-dark"><tr><th>Name</th><th>Price</th><th>Stock</th><th>Active</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>$@p.Price.ToString("N2")</td>
                <td>@p.Stock</td>
                <td>@(p.IsActive ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>