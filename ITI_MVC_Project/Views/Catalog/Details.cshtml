@model ProductDetailsVM
@{ ViewData["Title"] = Model.Name; }
<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Name" />
        }
        else
        {
            <div class="bg-secondary d-flex align-items-center justify-content-center rounded" style="height:400px;">
                <span class="text-white display-6">No Image</span>
            </div>
        }
    </div>
    <div class="col-md-6">
        <h2>@Model.Name</h2>
        <span class="badge bg-info mb-2">@Model.CategoryName</span>
        <h3 class="text-primary">$@Model.Price.ToString("N2")</h3>
        <p class="mt-3">@Model.Description</p>
        <p>
            @if (Model.InStock)
            {
                <span class="badge bg-success">In Stock (@Model.Stock available)</span>
            }
            else
            {
                <span class="badge bg-danger">Out of Stock</span>
            }
        </p>
        @if (Model.InStock)
        {
            <form asp-controller="Cart" asp-action="Add" method="post" class="mt-3">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="input-group" style="max-width:200px;">
                    <input type="number" name="quantity" value="1" min="1" max="@Model.Stock" class="form-control" />
                    <button type="submit" class="btn btn-primary">Add to Cart</button>
                </div>
            </form>
        }
        <a asp-action="Index" class="btn btn-outline-secondary mt-3">Back to Shop</a>
    </div>
</div>