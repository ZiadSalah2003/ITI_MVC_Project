@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mb-5">
    <h1 class="display-4">Welcome to ITI Store</h1>
    <p class="lead">Browse our catalog of amazing products</p>
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg mt-3">Shop Now</a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100 text-center p-4">
            <div class="card-body">
                <h5 class="card-title">Wide Selection</h5>
                <p class="card-text">Browse through multiple categories of products from electronics to books.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 text-center p-4">
            <div class="card-body">
                <h5 class="card-title">Secure Checkout</h5>
                <p class="card-text">Your orders are processed securely with full transaction support.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 text-center p-4">
            <div class="card-body">
                <h5 class="card-title">Order Tracking</h5>
                <p class="card-text">Track your orders and view complete order history.</p>
            </div>
        </div>
    </div>
</div>
